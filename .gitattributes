# Normalize line endings: store text as LF in the repo, so checkouts don't churn
# between LF/CRLF across platforms (silences the "LF will be replaced by CRLF" warnings).
* text=auto eol=lf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff  binary
*.woff2 binary
*.sqlite binary
*.faiss  binary
