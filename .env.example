# StoryWeave configuration — copy to .env and edit. All vars use the STORYWEAVE_ prefix.
# Defaults are local-first and free: with the LLM layer off, there are ZERO runtime
# outbound network calls (rule #5).

# --- Storage (local disk) ---
# STORYWEAVE_DATA_DIR=data
# STORYWEAVE_DB_PATH=data/storyweave.sqlite

# --- API ---
# STORYWEAVE_API_HOST=127.0.0.1
# STORYWEAVE_API_PORT=8000

# --- LLM enhancement layer — OFF BY DEFAULT (rules #4 and #5) ---
# Leave disabled for a fully-local, offline run. Enable only to opt into the
# optional Tier-2/Tier-3 enhancement path.
STORYWEAVE_LLM_ENABLED=false
# STORYWEAVE_LLM_BASE_URL=
# STORYWEAVE_LLM_MODEL=
# STORYWEAVE_LLM_API_KEY=
