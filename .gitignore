*.egg-info/
build/
dist/
.eggs/

# --- Tooling caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Frontend (Phase 8) ---
node_modules/
frontend/dist/
frontend/.vite/

