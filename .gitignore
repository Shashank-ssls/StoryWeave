# --- Virtual environments (off the C: drive, never committed) ---
.venv/
.venv-ml/

# --- Databases (SQLite is local source of truth, rebuildable; not committed) ---
*.sqlite
*.sqlite3
*.db

# --- Raw novel text (copyrighted / large; samples/ and labels/ ARE committed) ---
data/raw/*
!data/raw/.gitkeep

# --- Session-seed prompt files (local working notes; never committed) ---
*-prompt.md

# --- Secrets ---
.env

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# --- Tooling caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/

# --- Frontend (Phase 8) ---
node_modules/
frontend/dist/
frontend/.vite/
*.tsbuildinfo

# --- Vector store artifacts (rebuildable) ---
.chroma/
*.faiss

# --- Model weights cache (HuggingFace; large, on F:, re-downloadable) ---
.hf-cache/

# --- LLM runner + GGUF weights (Phase 7b; large, on F:, re-downloadable) ---
.llm-cache/
tools/
